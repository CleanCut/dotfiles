  "base_keymap": "VSCode",
  "agent": {
    "enabled": true,
    "button": true,
    "favorite_models": [],
    "model_parameters": [],
  },
  "show_signature_help_after_edits": false,
  "auto_signature_help": false,
  "multi_cursor_modifier": "alt",
  "minimap": {
    "show": "never",
  },
  "hover_popover_delay": 1000,
  "cursor_blink": false,
  "autosave": "on_focus_change",
  "buffer_font_fallbacks": ["Menlo", "Monaco", "Courier New", ".ZedMono"],
  "buffer_font_family": "Ubuntu Mono",
  "colorize_brackets": false,
  "show_edit_predictions": true,
  "semantic_tokens": "combined",
  "ensure_final_newline_on_save": true,
  "wrap_guides": [100],
  "ui_font_size": 16,
  "buffer_font_size": 14.0,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Monokai-og",
  },
  "theme_overrides": {
    "Monokai-og": {
      "hint": "#5f5c50",
      "error": "#ff6d67",
      "deleted": "#b06868",
      "terminal.background": "#1d1e1a",
      "terminal.ansi.black": "#000000",
      "terminal.ansi.bright_black": "#333333",
      "terminal.ansi.red": "#ec483e",
      "terminal.ansi.bright_red": "#ff6d67",
      "terminal.ansi.green": "#00c200",
      "terminal.ansi.bright_green": "#5ff967",
      "terminal.ansi.yellow": "#ffa400",
      "terminal.ansi.bright_yellow": "#ffdf00",
      "terminal.ansi.blue": "#0081ff",
      "terminal.ansi.bright_blue": "#00a6ff",
      "terminal.ansi.magenta": "#ae5fef",
      "terminal.ansi.bright_magenta": "#ff76ff",
      "terminal.ansi.cyan": "#00c5c7",
      "terminal.ansi.bright_cyan": "#5ffdff",
      "terminal.ansi.white": "#c7c7c7",
      "terminal.ansi.bright_white": "#feffff",
      "terminal.ansi.dim_white": "#8a8a8a",
      "terminal.foreground": "#c7c7c7",
      "terminal.bright_foreground": "#feffff",
      "terminal.dim_foreground": "#8a8a8a",
      "players": [
        {
          "cursor": "#0081ff",
          "background": "#0081ff",
          // "selection": "#a6b80033",
        },
      ],
      "syntax": {
        "punctuation": { "color": "#a9b7c6" },
        "punctuation.bracket": { "color": "#a9b7c6" },
        "punctuation.delimiter": { "color": "#a9b7c6" },
      },
    },
  },
  "inlay_hints": {
    "toggle_on_modifiers_press": {
      "control": true,
      "shift": false,
      "alt": true,
      "platform": false,
      "function": false,
    },
  },
}
